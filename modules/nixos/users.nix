{ config }: {
  # Don't allow mutation of users outside the config.
  users.mutableUsers = false;

  users.groups = {
    "gabehoban" = {};
    docker = {};
    dialout = {};
    # for openocd (embedded system development)
    plugdev = {};
    # misc
    uinput = {};
  };

  users.users."gabehoban" = {
    # generated by `mkpasswd -m scrypt`
    # we have to use initialHashedPassword here when using tmpfs for /
    initialHashedPassword = "$7$CU..../....4pm.YfTlZIn3yxrWDiSiZ.$x0dbd35YvFAEy8F3prOHZFBXmlt4srxgvnyjxAAtae4";
    home = "/home/gabehoban";
    isNormalUser = true;
    extraGroups = [
      "gabehoban"
      "users"
      "networkmanager"
      "wheel"
      "docker"
      "libvirtd"
    ];
    openssh.authorizedKeys.keys = [
      "ssh-rsa  cardno:17_077_465"
    ];
  };

  # root's ssh key are mainly used for remote deployment
  users.users.root = {
    initialHashedPassword = config.users.users."gabehoban".initialHashedPassword;
    openssh.authorizedKeys.keys = config.users.users."gabehoban".openssh.authorizedKeys.keys;
  };
}
